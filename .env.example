ASSEMBLYAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GITHUB_TOKEN=your_github_token_here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Optional overrides
# Default model: claude-haiku-4-5 (cheap, plenty for structured extraction).
# Use a stronger model only for the normalizer if you want sharper reasoning.
# CLAUDE_MODEL=claude-haiku-4-5
# CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5
# CLAUDE_NORMALIZER_MODEL=claude-sonnet-4-5
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# FAISS_THRESHOLD=0.45
# BACKEND_URL=http://localhost:8000
